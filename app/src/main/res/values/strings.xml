    <!-- Ollama on-device info -->
    <string name="ollama_local_hint">Install Ollama in Termux:\n1. Install Termux from F-Droid\n2. Run: pkg install ollama\n3. Run: ollama serve\n4. Pull a model: ollama pull gemma3:1b\n\nThe API endpoint will be set to http://localhost:11434/v1 automatically.</string>

    <!-- Gemini Nano backend -->
    <string name="backend_gemini_nano">Gemini Nano — via AI Edge SDK (Pixel 9+ / Android 15+)</string>
    <string name="gemini_nano_hint">Uses Google\'s system Gemini Nano model via the AI Edge SDK.\n\nNo model file to download — the model is built into the OS on supported devices.\n\nRequirements: Pixel 9 or newer, Android 15 (API 35)+.\n\nNote: The AI Edge SDK is experimental (v0.0.1-exp02) and subject to change.</string>

